{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "paths": {
      "@prev/jsx": ["./src/jsx/index.ts"],
      "@prev/components/*": ["./previews/components/*", "./previews/components/*/index.tsx"],
      "*": ["./*"]
    }
  },
  "include": ["src/**/*", "previews/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "src/theme/**/*"]
}
